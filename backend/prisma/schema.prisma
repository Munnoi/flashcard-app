generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  decks    Deck[]
}

model Deck {
  id     String @id @default(uuid())
  title  String
  userId String
  user   User   @relation(fields: [userId], references: [id])
  cards  Card[]
}

model Card {
  id       String @id @default(uuid())
  question String
  answer   String
  deckId   String
  deck     Deck   @relation(fields: [deckId], references: [id])
}
